---
/**
 * Gallery — responsives Bildraster.
 * Wiederverwendbar für alle bild-lastigen Seiten (Malzeit, Impressionen …).
 */
interface GalleryImage {
  src: string;
  alt: string;
}

interface Props {
  images: GalleryImage[];
}

const { images } = Astro.props;
---

<div class="gallery">
  <ul class="gallery__grid">
    {
      images.map((image) => (
        <li class="gallery__item media">
          <img
            src={image.src}
            alt={image.alt}
            width="600"
            height="600"
            loading="lazy"
            decoding="async"
          />
        </li>
      ))
    }
  </ul>
</div>

<style>
  .gallery__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: clamp(0.6rem, 2vw, 1.25rem);
  }
  @media (min-width: 720px) {
    .gallery__grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .gallery__item {
    aspect-ratio: 1 / 1;
    border-radius: var(--radius-md);
  }
  .gallery__item img {
    transition: transform 0.5s var(--ease);
  }
  .gallery__item:hover img {
    transform: scale(1.05);
  }
</style>
