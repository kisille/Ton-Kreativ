---
/**
 * Figure — wiederverwendbares Bild mit abgerundetem Rahmen.
 * Auf allen bild-lastigen Seiten einsetzbar.
 */
interface Props {
  src: string;
  alt: string;
  width?: number;
  height?: number;
  /** Seitenverhältnis als CSS-Wert, z.B. "4 / 5". */
  ratio?: string;
  /** Lade-Priorität für das wichtigste Bild oben. */
  eager?: boolean;
  /** Zusätzliche Klassen. */
  class?: string;
}

const {
  src,
  alt,
  width = 1200,
  height = 1500,
  ratio = '4 / 5',
  eager = false,
  class: className = '',
} = Astro.props;
---

<figure class:list={['figure', className]} style={`--ratio: ${ratio}`}>
  <div class="figure__media media">
    <img
      src={src}
      alt={alt}
      width={width}
      height={height}
      loading={eager ? 'eager' : 'lazy'}
      fetchpriority={eager ? 'high' : 'auto'}
      decoding="async"
    />
  </div>
</figure>

<style>
  .figure {
    margin: 0;
  }

  .figure__media {
    aspect-ratio: var(--ratio, 4 / 5);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
  }
</style>
