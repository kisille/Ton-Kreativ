---
/**
 * ServiceCard — wiederverwendbare Karte für eine Dienstleistung/Angebot.
 */
import { site } from '../data/site';

interface Props {
  title: string;
  image: string;
  alt: string;
  href?: string;
  cta?: string;
  /** Fotonachweis; Default = Guntram Fechtig. */
  credit?: string;
}

const { title, image, alt, href, cta, credit = site.photographer } = Astro.props;
---

<article class="card">
  <div class="card__media media">
    <img src={image} alt={alt} width="640" height="480" loading="lazy" />
    {credit && <span class="card__credit">Foto: {credit}</span>}
  </div>
  <div class="card__body">
    <h3 class="card__title">{title}</h3>
    <p class="card__text"><slot /></p>
    {
      href && (
        <a class="card__link" href={href}>
          {cta ?? 'Mehr erfahren'}
          <span aria-hidden="true">→</span>
        </a>
      )
    }
  </div>
</article>

<style>
  .card {
    display: flex;
    flex-direction: column;
    background: var(--white);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: transform var(--transition), box-shadow var(--transition);
  }
  .card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
  }

  .card__media {
    aspect-ratio: 4 / 3;
    border-radius: 0;
  }
  .card__credit {
    position: absolute;
    left: 0;
    bottom: 0;
    padding: 0.3rem 0.7rem;
    font-size: 0.68rem;
    letter-spacing: 0.04em;
    color: var(--cream);
    background: color-mix(in srgb, var(--ink) 55%, transparent);
    border-radius: 0 var(--radius-sm) 0 0;
  }
  .card:hover .card__media img {
    transform: scale(1.04);
  }
  .card__media img {
    transition: transform 0.5s var(--ease);
  }

  .card__body {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    padding: var(--space-lg) var(--space-lg) var(--space-xl);
  }
  .card__text {
    color: var(--muted);
    margin: 0;
  }
  .card__link {
    margin-top: auto;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-weight: 600;
    color: var(--terracotta);
    padding-top: var(--space-sm);
    transition: gap var(--transition);
  }
  .card__link:hover {
    gap: 0.7rem;
  }
</style>
