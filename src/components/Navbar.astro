---
/**
 * Navbar — sticky Kopfzeile mit Wortmarke und Navigation.
 * Desktop: horizontale Links. Mobil: Hamburger öffnet ein Vollflächen-Menü.
 */
import { navLinks } from '../data/site';

// Aktuellen Pfad für die "active"-Markierung ermitteln.
const current = Astro.url.pathname.replace(/\/+$/, '') || '/';
---

<header class="site-header">
  <div class="container nav-bar">
    <a class="brand" href="/" aria-label="Ton-kreativ — Startseite">
      <span class="brand__mark" aria-hidden="true"></span>
      <span class="brand__name">Ton<span>-</span>kreativ</span>
    </a>

    <button
      class="nav-toggle"
      type="button"
      aria-expanded="false"
      aria-controls="primary-nav"
      aria-label="Menü öffnen"
    >
      <span class="nav-toggle__bar"></span>
      <span class="nav-toggle__bar"></span>
      <span class="nav-toggle__bar"></span>
    </button>

    <nav id="primary-nav" class="nav" aria-label="Hauptnavigation">
      <ul class="nav__list">
        {
          navLinks.map((link) => {
            const href = link.href.replace(/\/+$/, '') || '/';
            const isActive = href === current;
            return (
              <li>
                <a
                  href={link.href}
                  class:list={['nav__link', { 'is-active': isActive }]}
                  aria-current={isActive ? 'page' : undefined}
                >
                  {link.label}
                </a>
              </li>
            );
          })
        }
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background-color: color-mix(in srgb, var(--cream) 88%, transparent);
    -webkit-backdrop-filter: saturate(140%) blur(8px);
    backdrop-filter: saturate(140%) blur(8px);
    border-bottom: 1px solid var(--line);
  }

  .nav-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-lg);
    min-height: var(--header-h);
  }

  /* Wortmarke */
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-family: var(--font-display);
    font-size: 1.3rem;
    letter-spacing: -0.01em;
    color: var(--ink);
    flex: none;
    white-space: nowrap;
  }
  .brand__name {
    white-space: nowrap;
  }
  .brand__mark {
    width: 1.05rem;
    height: 1.35rem;
    background: var(--terracotta);
    border-radius: 45% 45% 50% 50% / 60% 60% 40% 40%;
    flex: none;
  }
  .brand__name span {
    color: var(--terracotta);
  }

  /* Desktop-Navigation */
  .nav__list {
    display: flex;
    align-items: center;
    gap: clamp(0.5rem, 0.7vw, 0.72rem);
    flex-wrap: nowrap;
    justify-content: flex-end;
  }
  .nav__link {
    font-size: 0.76rem;
    font-weight: 500;
    color: var(--ink);
    padding: 0.35rem 0;
    position: relative;
    white-space: nowrap;
    transition: color var(--transition);
  }
  .nav__link::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: -2px;
    width: 100%;
    height: 1.5px;
    background: var(--terracotta);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform var(--transition);
  }
  .nav__link:hover,
  .nav__link.is-active {
    color: var(--terracotta);
  }
  .nav__link:hover::after,
  .nav__link.is-active::after {
    transform: scaleX(1);
  }

  /* Hamburger — auf Desktop versteckt */
  .nav-toggle {
    display: none;
    width: 2.75rem;
    height: 2.75rem;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 5px;
    border-radius: var(--radius-sm);
    /* Über dem geöffneten Off-Canvas-Menü (z-index: 90) halten, sonst
       verdeckt das Panel den Schließen-Button (X). */
    position: relative;
    z-index: 110;
  }
  .nav-toggle__bar {
    display: block;
    width: 1.4rem;
    height: 2px;
    background: var(--ink);
    transition: transform var(--transition), opacity var(--transition);
  }

  /* --------- Desktop: Wortmarke links, Navigation rechts auf zwei Zeilen --------- */
  @media (min-width: 1241px) {
    /* Wortmarke links | Navigation mittig (page-zentriert) | Ausgleich rechts */
    .nav-bar {
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      align-items: center;
      gap: 0;
      padding-block: 1.15rem;
    }
    .brand {
      justify-self: start;
    }
    .nav__list {
      justify-content: center;
      flex-wrap: wrap;
      /* grosszügiger Zeilenabstand (vertikal) für mehr Übersicht. */
      gap: 1.1rem clamp(0.9rem, 1.3vw, 1.2rem);
      max-width: 50rem;
      margin-inline: auto;
    }
    .nav__link {
      font-size: 0.95rem;
      padding: 0.25rem 0;
    }
  }

  /* --------- Mobil: Off-Canvas-Menü unter 1240px --------- */
  @media (max-width: 1240px) {
    /* Wichtig: backdrop-filter macht den Header zum containing block für
       fixed-Kinder und würde das Off-Canvas-Menü an der Headerleiste statt
       am Viewport ausrichten. Auf Mobil daher deaktivieren. */
    .site-header {
      backdrop-filter: none;
      -webkit-backdrop-filter: none;
      background-color: var(--cream);
      /* X / Wortmarke unter dem Notch bzw. der Dynamic Island freihalten. */
      padding-top: env(safe-area-inset-top);
    }

    .nav-toggle {
      display: inline-flex;
    }

    .nav {
      position: fixed;
      /* Volle Fläche abdecken (unter dem schwebenden Header), damit beim
         Öffnen nirgends das Hintergrundbild durchscheint. */
      top: 0;
      left: 0;
      right: 0;
      /* Exakte sichtbare Höhe (dvh): deckt auch hinter die kompakte iOS-Bar,
         ragt aber NICHT dahinter hinaus → kein zurückbleibender beiger Streifen
         beim Schließen. Da kein Scroll-Lock die URL-Leiste umschaltet, bleibt
         dvh konstant (kein Nachblenden). */
      height: 100vh; /* Fallback */
      height: 100dvh;
      background: var(--cream);
      z-index: 90;
      /* Geschlossen: SOFORT ausblenden. Ein animiertes Fade-out lässt iOS den
         Bereich hinter der schwebenden URL-Leiste verzögert neu zeichnen → der
         beige Streifen unten "hängt" 0,2–0,5 s nach. Instant-Close vermeidet
         das. Das Einblenden wird im .nav-open-Block sanft animiert. */
      opacity: 0;
      transition: opacity 0s, visibility 0s;
      overflow-y: auto;
      -webkit-overflow-scrolling: touch;
      overscroll-behavior: contain;
      padding-top: calc(
        var(--header-h) + var(--space-lg) + env(safe-area-inset-top)
      );
      padding-inline: var(--gutter);
      /* Letzten Link nicht unter den iOS-Home-Indikator schieben. */
      padding-bottom: max(var(--space-2xl), env(safe-area-inset-bottom));
      visibility: hidden;
    }
    .nav__list {
      flex-direction: column;
      align-items: flex-start;
      gap: 0;
    }
    .nav__list li {
      width: 100%;
      border-bottom: 1px solid var(--line);
    }
    .nav__link {
      display: block;
      width: 100%;
      padding: 1rem 0;
      font-size: 1.1rem;
      font-family: var(--font-display);
    }
    .nav__link::after {
      display: none;
    }

    /* Geöffneter Zustand (Klasse via JS auf <body>) */
    :global(body.nav-open) .nav {
      opacity: 1;
      visibility: visible;
      transition: opacity 0.3s var(--ease);
    }
    /* Kein CSS-Scroll-Lock (kein position:fixed/overflow auf <body>) → die Seite
       verschiebt sich beim Öffnen NICHT und die iOS-URL-Leiste wird nicht
       umgeschaltet. Das Scrollen der Hintergrundseite wird stattdessen per JS
       (touchmove) unterbunden. */
    /* Hamburger -> X */
    :global(body.nav-open) .nav-toggle__bar:nth-child(1) {
      transform: translateY(7px) rotate(45deg);
    }
    :global(body.nav-open) .nav-toggle__bar:nth-child(2) {
      opacity: 0;
    }
    :global(body.nav-open) .nav-toggle__bar:nth-child(3) {
      transform: translateY(-7px) rotate(-45deg);
    }
  }
</style>

<script>
  // Hamburger-Menü: Body-Klasse umschalten, ARIA pflegen, bei Navigation/ESC schließen.
  const toggle = document.querySelector('.nav-toggle');
  const nav = document.getElementById('primary-nav');

  // Hintergrund-Scroll sperren OHNE Layout-Änderung (kein Versatz!): Touch-Scroll
  // außerhalb des Menüs unterbinden. Das Menü selbst darf scrollen, falls sein
  // Inhalt höher als der Bildschirm ist. Da weder position:fixed noch overflow
  // gesetzt wird, verschiebt sich die Seite nicht und die iOS-URL-Leiste bleibt
  // unverändert (→ kein Nachblenden, kein Versatz).
  function lockScroll(e: TouchEvent) {
    const target = e.target as Node;
    const canScrollInsideMenu =
      !!nav && nav.contains(target) && nav.scrollHeight > nav.clientHeight;
    if (!canScrollInsideMenu) e.preventDefault();
  }

  function setOpen(open: boolean) {
    document.body.classList.toggle('nav-open', open);
    if (open) {
      document.addEventListener('touchmove', lockScroll, { passive: false });
    } else {
      document.removeEventListener('touchmove', lockScroll);
    }
    toggle?.setAttribute('aria-expanded', String(open));
    toggle?.setAttribute('aria-label', open ? 'Menü schließen' : 'Menü öffnen');
  }

  toggle?.addEventListener('click', () => {
    setOpen(!document.body.classList.contains('nav-open'));
  });

  // Beim Klick auf einen Link schließen.
  nav?.addEventListener('click', (e) => {
    if ((e.target as HTMLElement).closest('a')) setOpen(false);
  });

  // ESC schließt das Menü.
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') setOpen(false);
  });
</script>
