---
/**
 * Hero — vollflächiges Atmosphäre-Bild (Hände am Ton) mit Text-Overlay.
 * Das Foto ist der "Star of the Show"; ein Verlauf sorgt für Lesbarkeit.
 */
import { img, photos } from '../data/site';
const heroImg = img(photos.heroHome);
---

<section class="hero">
  <img
    class="hero__bg"
    src={heroImg}
    alt="Hände gestalten ein Werkstück aus Ton im Atelier Ton-kreativ"
    width="1600"
    height="747"
    fetchpriority="high"
    decoding="async"
  />
  <div class="hero__scrim" aria-hidden="true"></div>

  <div class="container hero__inner">
    <div class="hero__text">
      <span class="eyebrow">Töpfer- &amp; Keramik-Atelier · Satteins</span>
      <h1>Willkommen bei Ton-kreativ</h1>
      <p class="lead">
        Ich bin Jana — Mutter dreier Kids und der Mensch hinter Ton-Kreativ.
        Bei mir darfst du in Ruhe gestalten, malen und töpfern. Ganz ohne
        Leistungsdruck, dafür mit viel Herz.
      </p>
      <div class="hero__actions">
        <a class="btn btn--primary" href="/buche-malzeit">Malzeit buchen</a>
        <a class="btn btn--ghost" href="/ueber-mich">Über mich</a>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    display: flex;
    align-items: center;
    /* Füllt die volle Bildschirmhöhe — das Bild geht bis zum unteren Rand,
       die nächste Sektion ("Was dich erwartet") liegt erst unter der Kante. */
    min-height: 100vh;
    min-height: 100svh;
    overflow: hidden;
    isolation: isolate;
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    z-index: -2;
  }

  /* Verlauf für Lesbarkeit: links und unten dunkler. */
  .hero__scrim {
    position: absolute;
    inset: 0;
    z-index: -1;
    background:
      linear-gradient(
        to right,
        rgba(26, 22, 18, 0.72) 0%,
        rgba(26, 22, 18, 0.45) 35%,
        rgba(26, 22, 18, 0) 72%
      ),
      linear-gradient(
        to top,
        rgba(26, 22, 18, 0.6) 0%,
        rgba(26, 22, 18, 0) 55%
      );
  }

  .hero__inner {
    width: 100%;
    padding-block: clamp(2.5rem, 6vw, 4.5rem);
  }
  .hero__text {
    max-width: 40rem;
  }

  /* Helle Typografie auf dem Bild */
  .hero .eyebrow {
    color: color-mix(in srgb, var(--terracotta) 55%, var(--cream));
  }
  .hero h1 {
    color: var(--cream);
    margin-bottom: var(--space-lg);
  }
  .hero .lead {
    /* etwas zurückgenommen (Hierarchie), aber gut lesbar auf dem Bild */
    color: color-mix(in srgb, var(--cream) 88%, transparent);
    max-width: 34rem;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
    margin-top: var(--space-xl);
  }
  /* Ghost-Button auf dunklem Grund hell */
  .hero .btn--ghost {
    color: var(--cream);
    border-color: color-mix(in srgb, var(--cream) 55%, transparent);
  }
  .hero .btn--ghost:hover {
    background: var(--cream);
    color: var(--ink);
    border-color: var(--cream);
  }
</style>
