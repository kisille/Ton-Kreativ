---
/**
 * Hero — Willkommens-Sektion der Startseite mit großem Atmosphärenbild.
 */
import { img, photos } from '../data/site';
const heroImg = img(photos.janaPortrait);
---

<section class="hero">
  <div class="container hero__inner">
    <div class="hero__text">
      <span class="eyebrow">Töpfer- &amp; Keramik-Atelier · Satteins</span>
      <h1>Willkommen bei Ton-kreativ</h1>
      <p class="lead">
        Ich bin Jana — Mutter dreier Kids und der Mensch hinter Ton-Kreativ.
        Bei mir darfst du in Ruhe gestalten, malen und töpfern. Ganz ohne
        Leistungsdruck, dafür mit viel Herz.
      </p>
      <div class="hero__actions">
        <a class="btn btn--primary" href="/buche-malzeit">Malzeit buchen</a>
        <a class="btn btn--ghost" href="/ueber-mich">Über mich</a>
      </div>
    </div>

    <figure class="hero__media media">
      <img
        src={heroImg}
        alt="Jana Gams in ihrem Töpfer- und Keramik-Atelier Ton-kreativ"
        width="960"
        height="1200"
        fetchpriority="high"
      />
    </figure>
  </div>
</section>

<style>
  .hero {
    padding-block: clamp(2.5rem, 6vw, 5rem);
  }

  .hero__inner {
    display: grid;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: center;
  }

  .hero__text {
    max-width: 38rem;
  }
  .hero h1 {
    margin-bottom: var(--space-lg);
  }
  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
    margin-top: var(--space-xl);
  }

  .hero__media {
    aspect-ratio: 4 / 5;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
  }

  @media (min-width: 880px) {
    .hero__inner {
      grid-template-columns: 1.05fr 0.95fr;
    }
    .hero__media {
      aspect-ratio: 4 / 5;
      max-width: 30rem;
      margin-left: auto;
    }
  }
</style>
