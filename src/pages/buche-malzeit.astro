---
/**
 * Buche deine Malzeit (Projekt-Brief §2).
 * Buchungs-Widget (Teburio, eingebettet + Button), Öffnungszeiten, Ablauf,
 * Stornierung, besondere Anlässe und Malzeit-Galerie.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Figure from '../components/Figure.astro';
import Gallery from '../components/Gallery.astro';
import { img, photos, galleries, booking, site } from '../data/site';

const openingHours = [
  { day: 'Donnerstag', time: '14:00 – 18:30' },
  { day: 'Freitag', time: '14:00 – 21:00' },
  { day: 'Samstag', time: '9:30 – 18:30' },
];

const holidays = ['05.06. geschlossen', '16.07. – 20.07.', '24.08. – 27.08.'];

const occasions = [
  {
    title: 'Kindergarten & Schule',
    text: 'Termine ausserhalb der Öffnungszeiten ab 12 Kindern. Schreib mir einfach eine Mail, dann finden wir einen passenden Zeitpunkt.',
  },
  {
    title: 'Junggesellinnenabschied (JGA)',
    text: 'Bemalt z. B. das Frühstücksgeschirr fürs Brautpaar. Einfache Maltechniken — alle können mitmachen. Ab 6 Personen, auch ausserhalb der Öffnungszeiten. Sekt und Getränke gibt es vor Ort.',
  },
  {
    title: 'Feiern mit dem Team oder privat',
    text: 'Ob Teamausflug oder privates Treffen: Schreib mir eine Mail, Termine sind auch ausserhalb der Öffnungszeiten möglich.',
  },
];

const malzeitGallery = galleries.malzeit.map((file, i) => ({
  src: img(file),
  alt: `Bemalte Keramik aus dem Atelier Ton-kreativ (${i + 1})`,
}));
---

<BaseLayout
  title="Buche deine Malzeit — Ton-kreativ"
  description="Keramik bemalen im Atelier Ton-kreativ: Malplatz online buchen, 2 Stunden Malzeit, alle Brände & Farben inklusive. Öffnungszeiten, Ablauf und Infos zu Gruppen, JGA & Feiern."
>
  <!-- Intro -->
  <section class="section book-hero">
    <div class="container book-hero__inner">
      <div class="book-hero__text">
        <span class="eyebrow">Keramik bemalen</span>
        <h1>Buche deine Malzeit</h1>
        <p class="lead">
          Such dir ein Lieblingsstück aus und gestalte es ganz nach deinem
          Geschmack. Du hast 2 Stunden Zeit zum Malen — in den Keramikkosten ist
          alles enthalten: beide Brände, die Farben und die abschliessende Arbeit
          (klar glasieren, Stellrand säubern).
        </p>
        <a class="btn btn--primary" href={booking.malplatz} target="_blank" rel="noopener noreferrer">
          Malplatz buchen
        </a>
      </div>
      <Figure
        src={img(photos.malzeit)}
        alt="Tisch mit Farben und Keramik zum Bemalen im Atelier"
        ratio="4 / 5"
        eager={true}
        class="book-hero__figure"
      />
    </div>
  </section>

  <!-- Buchungs-Widget -->
  <section class="section section--sand" id="buchen">
    <div class="container">
      <header class="section-head text-center">
        <span class="eyebrow">Online buchen</span>
        <h2>Reserviere deinen Malplatz</h2>
        <p class="lead">
          Wähle direkt im Buchungskalender deinen Wunschtermin. Falls das Fenster
          nicht angezeigt wird, gelangst du über den Button zum Buchungssystem.
        </p>
      </header>

      <div class="booking">
        <div class="booking__embed">
          <iframe
            src={booking.malplatz}
            title="Malplatz buchen — Buchungssystem Teburio"
            loading="lazy"
            allow="payment"
          ></iframe>
        </div>
        <p class="booking__fallback">
          Das Buchungsfenster lädt nicht?
          <a href={booking.malplatz} target="_blank" rel="noopener noreferrer">
            Hier direkt buchen →
          </a>
        </p>
      </div>
    </div>
  </section>

  <!-- Öffnungszeiten & Urlaub -->
  <section class="section">
    <div class="container hours">
      <div class="hours__card">
        <span class="eyebrow">Öffnungszeiten</span>
        <h2>Wann du vorbeikommen kannst</h2>
        <table class="hours__table">
          <tbody>
            {openingHours.map((row) => (
              <tr>
                <th scope="row">{row.day}</th>
                <td>{row.time}</td>
              </tr>
            ))}
          </tbody>
        </table>
        <p class="hours__note">Gruppen gern nach Vereinbarung.</p>
      </div>

      <div class="hours__card hours__card--muted">
        <span class="eyebrow">Urlaub &amp; geschlossen</span>
        <h2>An diesen Tagen geschlossen</h2>
        <ul class="hours__holidays">
          {holidays.map((d) => <li>{d}</li>)}
        </ul>
        <p class="hours__note">Ab 8 Personen bitte vorab per Mail anfragen.</p>
      </div>
    </div>
  </section>

  <!-- Ablauf & Stornierung -->
  <section class="section section--sand">
    <div class="container info-grid">
      <article class="info">
        <span class="eyebrow">So funktioniert die Buchung</span>
        <h2>Schnell &amp; unkompliziert</h2>
        <ul class="info__list">
          <li>
            Zum Buchen hinterlegst du eine Kredit- oder Debitkarte. Der Betrag
            wird <strong>nicht abgebucht</strong>, sondern nur geblockt — als
            Schutz bei Nichterscheinen oder zu später Stornierung.
          </li>
          <li>
            Nach deinem Besuch wird die Blockierung wieder freigegeben (das
            dauert 3–5 Tage). Bezahlt wird bequem vor Ort.
          </li>
          <li>Ab 8 Personen bitte per Mail anfragen.</li>
        </ul>
      </article>

      <article class="info">
        <span class="eyebrow">Stornierung</span>
        <h2>Flexibel bleiben</h2>
        <ul class="info__list">
          <li>
            Kostenlos bis 2 Tage vorher — den Stornolink findest du in deiner
            Bestätigungsmail.
          </li>
          <li>
            Bei kurzfristiger Absage oder Nichterscheinen wird ein Mindestumsatz
            pro Platz berechnet.
          </li>
          <li>Eine Ersatzperson kannst du natürlich jederzeit schicken.</li>
        </ul>
      </article>
    </div>
  </section>

  <!-- Besondere Anlässe -->
  <section class="section">
    <div class="container">
      <header class="section-head text-center">
        <span class="eyebrow">Besondere Anlässe</span>
        <h2>Feiern, Gruppen &amp; mehr</h2>
        <p class="lead">
          Du möchtest mit einer grösseren Gruppe vorbeikommen? Das geht — auch
          ausserhalb der regulären Öffnungszeiten.
        </p>
      </header>

      <div class="occasion-grid">
        {occasions.map((o) => (
          <article class="occasion">
            <h3>{o.title}</h3>
            <p>{o.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Galerie -->
  <section class="section section--sand">
    <div class="container">
      <header class="section-head text-center">
        <span class="eyebrow">Impressionen</span>
        <h2>Werke aus der Malzeit</h2>
      </header>
      <Gallery images={malzeitGallery} />
    </div>
  </section>

  <!-- CTA -->
  <section class="section book-cta">
    <div class="container container--narrow text-center">
      <h2>Bereit für deine Malzeit?</h2>
      <p class="lead">Sichere dir deinen Platz oder schreib mir bei Fragen.</p>
      <div class="book-cta__actions">
        <a class="btn btn--primary" href={booking.malplatz} target="_blank" rel="noopener noreferrer">
          Malplatz buchen
        </a>
        <a class="btn btn--ghost" href={`mailto:${site.email}`}>{site.email}</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .section-head {
    max-width: 52rem;
    margin-inline: auto;
    margin-bottom: clamp(2rem, 5vw, 3.5rem);
  }
  .section-head h2 {
    margin-bottom: var(--space-md);
  }

  /* Intro */
  .book-hero__inner {
    display: grid;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: center;
  }
  .book-hero__text {
    max-width: 38rem;
  }
  .book-hero h1 {
    margin-bottom: var(--space-lg);
  }
  .book-hero .btn {
    margin-top: var(--space-xl);
  }
  @media (min-width: 880px) {
    .book-hero__inner {
      grid-template-columns: 1.05fr 0.95fr;
    }
    .book-hero__figure {
      max-width: 28rem;
      margin-left: auto;
    }
  }

  /* Buchungs-Widget */
  .booking {
    max-width: 820px;
    margin-inline: auto;
  }
  .booking__embed {
    background: var(--white);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-md);
  }
  .booking__embed iframe {
    display: block;
    width: 100%;
    height: 760px;
    border: 0;
  }
  .booking__fallback {
    text-align: center;
    margin-top: var(--space-md);
    font-size: 0.9rem;
    color: var(--muted);
  }
  .booking__fallback a {
    color: var(--terracotta);
    font-weight: 600;
  }

  /* Öffnungszeiten */
  .hours {
    display: grid;
    gap: clamp(1.5rem, 4vw, 2.5rem);
  }
  @media (min-width: 760px) {
    .hours {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  .hours__card {
    padding: clamp(1.75rem, 4vw, 2.5rem);
    background: var(--white);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
  }
  .hours__card--muted {
    background: var(--sand-soft);
  }
  .hours__card h2 {
    font-size: clamp(1.5rem, 2.5vw, 2rem);
    margin-bottom: var(--space-lg);
  }
  .hours__table {
    width: 100%;
    border-collapse: collapse;
  }
  .hours__table th,
  .hours__table td {
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--line);
    text-align: left;
  }
  .hours__table th {
    font-weight: 500;
  }
  .hours__table td {
    text-align: right;
    font-variant-numeric: tabular-nums;
    color: var(--ink);
  }
  .hours__holidays {
    display: grid;
    gap: 0.6rem;
  }
  .hours__holidays li {
    padding: 0.7rem 1rem;
    background: var(--white);
    border-radius: var(--radius-sm);
    border: 1px solid var(--line);
    font-variant-numeric: tabular-nums;
  }
  .hours__note {
    margin-top: var(--space-lg);
    color: var(--muted);
    font-size: 0.92rem;
  }

  /* Ablauf & Storno */
  .info-grid {
    display: grid;
    gap: clamp(2rem, 5vw, 3.5rem);
  }
  @media (min-width: 760px) {
    .info-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  .info h2 {
    font-size: clamp(1.5rem, 2.5vw, 2rem);
    margin-bottom: var(--space-lg);
  }
  .info__list {
    display: grid;
    gap: var(--space-md);
  }
  .info__list li {
    position: relative;
    padding-left: 1.6rem;
    color: var(--muted);
  }
  .info__list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.6rem;
    width: 0.55rem;
    height: 0.55rem;
    border-radius: 50%;
    background: var(--terracotta);
  }
  .info__list strong {
    color: var(--ink);
  }

  /* Besondere Anlässe */
  .occasion-grid {
    display: grid;
    gap: clamp(1.25rem, 3vw, 2rem);
  }
  @media (min-width: 760px) {
    .occasion-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  .occasion {
    padding: clamp(1.5rem, 3vw, 2rem);
    background: var(--cream);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    border-top: 3px solid var(--terracotta);
  }
  .occasion h3 {
    margin-bottom: var(--space-sm);
  }
  .occasion p {
    color: var(--muted);
    margin: 0;
  }

  /* CTA */
  .book-cta__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
    justify-content: center;
    margin-top: var(--space-xl);
  }
</style>
