---
/**
 * Impressionen und Feedback (Projekt-Brief §8).
 * Kundenstimmen, Einblicke in Veranstaltungen und Werk-Galerie.
 * Die Bewertungs-/Kommentarfunktion (Backend) folgt am Schluss — vorerst
 * ein Hinweis-Block.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Gallery from '../components/Gallery.astro';
import { img, galleries, site } from '../data/site';

const testimonials = [
  {
    name: 'Claudia Hartl',
    stars: 5,
    text: 'Ein wirklich gelungener Teamausflug! Das Töpfern hat großen Spaß gemacht und war eine tolle gemeinsame Erfahrung. Jana hat den Kurs super sympathisch und geduldig geleitet, sodass sich alle sofort wohlgefühlt haben. Sehr angenehme Atmosphäre und absolut empfehlenswert.',
  },
  {
    name: 'Nadine',
    stars: 5,
    text:
      'Wir waren zu viert in Janas Töpferstudio und es war ein wunderschöner Abend. Wir hatten alle keine Töpfererfahrung, wurden durch Jana aber super unterstützt und waren so alle mit dem Endergebnis happy. Jana ist unfassbar kreativ und hatte immer einen passenden Gestaltungstipp parat.\n\n' +
      'Ich kann den Besuch bei Jana aus mehreren Gründen von Herzen empfehlen. Einerseits ist es der perfekte Abend für die Freundschaft, da man einfach zusammen am Tisch sitzt und wunderschöne Gespräche führen kann. Andererseits fanden wir das Töpfern total meditativ und waren am Ende super entspannt und erholt vom stressigen Arbeitstag. Und als ob das noch nicht genug wäre, erhält man nach dem Trocknungsprozess sein individuelles Töpfer-Kunstwerk!\n\n' +
      'Hinzu kommt, dass man sich bei Jana einfach wohlfühlt. Sie unterstützt, wo Unterstützung gebraucht wird, und lässt einem dennoch sehr viele Freiheiten, sodass man sich „austoben“ kann. Der Töpfer-Raum ist so liebevoll gestaltet und Jana schafft es, dass man sich wie Zuhause fühlt.\n\n' +
      'Wir kommen auf jeden Fall wieder!',
  },
  {
    name: 'Lotta',
    stars: 5,
    text: 'Super!',
  },
];

const insights = [
  {
    title: 'Kindergeburtstag',
    text: 'Bis zu 6 Personen feiern gemeinsam. Muffins sind erlaubt, es gibt eine Kuchenpause und eine kleine Überraschung fürs Geburtstagskind.',
  },
  {
    title: 'Weihnachtswerkstatt für Kinder',
    text: 'Bei Crêpes und Kinderpunsch entstehen Teller, Schneemänner, Baumschmuck und Engel — die anschliessend liebevoll bemalt werden.',
  },
  {
    title: 'Wir töpfern einen Becher',
    text: 'Gross und klein werden gemeinsam kreativ — und am Ende nehmen alle ihren eigenen Becher mit nach Hause.',
  },
  {
    title: 'Gauki — Ferienprogramm',
    text: 'Beim Ferienprogramm wird mit Kindern und Erwachsenen getöpfert und gestaltet — für unvergessliche Ferientage.',
  },
];

const impressionen = galleries.impressionen.map((file, i) => ({
  src: img(file),
  alt: `Eindruck aus dem Atelier Ton-kreativ (${i + 1})`,
}));
---

<BaseLayout
  title="Impressionen & Feedback — Ton-kreativ"
  description="Kundenstimmen, Einblicke in Geburtstage, Kurse und die Weihnachtswerkstatt sowie eine Galerie der neuesten Werke aus dem Atelier Ton-kreativ."
>
  <!-- Intro -->
  <section class="section imp-hero">
    <div class="container container--narrow text-center">
      <span class="eyebrow">Impressionen &amp; Feedback</span>
      <h1>Eindrücke aus dem Atelier</h1>
      <p class="lead">
        Ob Kindergeburtstag, Kurs oder kreativer Abend — hier bekommst du einen
        Eindruck davon, was bei Ton-kreativ entsteht, und was unsere Gäste
        erlebt haben.
      </p>
    </div>
  </section>

  <!-- Kundenstimmen -->
  <section class="section section--sand" id="feedback">
    <div class="container">
      <header class="section-head text-center">
        <span class="eyebrow">Kundenstimmen</span>
        <h2>Das sagen unsere Gäste</h2>
      </header>

      <div class="testimonials">
        {testimonials.map((t) => (
          <figure class="testimonial">
            <div class="testimonial__stars" aria-label={`${t.stars} von 5 Sternen`}>
              {'★'.repeat(t.stars)}
            </div>
            <blockquote class="testimonial__text">{t.text}</blockquote>
            <button class="testimonial__toggle" type="button" aria-expanded="false" hidden>
              Mehr lesen
            </button>
            <figcaption class="testimonial__name">{t.name}</figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- Einblicke -->
  <section class="section">
    <div class="container">
      <header class="section-head text-center">
        <span class="eyebrow">Einblicke</span>
        <h2>Was bei uns so los ist</h2>
      </header>

      <div class="insight-grid">
        {insights.map((item) => (
          <article class="insight">
            <h3>{item.title}</h3>
            <p>{item.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Galerie der Werke -->
  <section class="section section--sand">
    <div class="container">
      <header class="section-head text-center">
        <span class="eyebrow">Galerie</span>
        <h2>Unsere neuesten Arbeiten</h2>
      </header>
      <Gallery images={impressionen} />
    </div>
  </section>

  <!-- Hinweis: Bewertungsfunktion folgt -->
  <section class="section">
    <div class="container container--narrow">
      <aside class="feedback-note">
        <span class="feedback-note__stars" aria-hidden="true">★★★★★</span>
        <h2>Du möchtest eine Bewertung hinterlassen?</h2>
        <p>
          Die Bewertungs- und Kommentarfunktion folgt in Kürze. Bis dahin freue
          ich mich riesig über dein Feedback per Mail — und sage schon jetzt
          herzlichen Dank!
        </p>
        <div class="feedback-note__actions">
          <a class="btn btn--primary" href={`mailto:${site.email}`}>Feedback per Mail</a>
          <a class="btn btn--ghost" href="/kontakt">Zum Kontakt</a>
        </div>
      </aside>
    </div>
  </section>
</BaseLayout>

<style>
  .section-head {
    max-width: 52rem;
    margin-inline: auto;
    margin-bottom: clamp(2rem, 5vw, 3.5rem);
  }
  .section-head h2 {
    margin-bottom: var(--space-md);
  }

  /* Intro */
  .imp-hero h1 {
    margin-bottom: var(--space-lg);
  }

  /* Kundenstimmen */
  .testimonials {
    display: grid;
    gap: clamp(1.25rem, 3vw, 2rem);
    max-width: 60rem;
    margin-inline: auto;
  }
  @media (min-width: 760px) {
    .testimonials {
      grid-template-columns: repeat(auto-fit, minmax(20rem, 1fr));
    }
  }
  .testimonial {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    margin: 0;
    padding: clamp(1.5rem, 3vw, 2rem);
    background: var(--white);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
  }
  .testimonial__stars {
    color: var(--terracotta);
    font-size: 1.1rem;
    letter-spacing: 0.15em;
  }
  .testimonial__text {
    margin: 0;
    font-family: var(--font-display);
    font-size: 1.15rem;
    line-height: 1.5;
    color: var(--ink);
    flex: 1;
    /* Echte Absätze aus dem \n\n im Text darstellen. */
    white-space: pre-line;
  }
  /* Eingeklappter Zustand (per JS gesetzt, wenn der Text zu lang ist). */
  .testimonial__text.is-clamped {
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 6;
    overflow: hidden;
    white-space: pre-line;
  }
  .testimonial__toggle {
    align-self: flex-start;
    padding: 0;
    font-size: 0.92rem;
    font-weight: 600;
    color: var(--terracotta);
    background: none;
    border: none;
    cursor: pointer;
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .testimonial__toggle:hover {
    color: var(--terracotta-dark);
  }
  .testimonial__name {
    font-weight: 600;
    color: var(--muted);
  }
  .testimonial__name::before {
    content: '— ';
  }

  /* Einblicke */
  .insight-grid {
    display: grid;
    gap: clamp(1.25rem, 3vw, 1.75rem);
  }
  @media (min-width: 680px) {
    .insight-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  .insight {
    padding: clamp(1.5rem, 3vw, 2rem);
    background: var(--cream);
    border: 1px solid var(--line);
    border-left: 3px solid var(--terracotta);
    border-radius: var(--radius-md);
  }
  .insight h3 {
    margin-bottom: var(--space-sm);
  }
  .insight p {
    color: var(--muted);
    margin: 0;
  }

  /* Hinweis-Block */
  .feedback-note {
    text-align: center;
    padding: clamp(2rem, 5vw, 3.5rem);
    background: var(--ink);
    color: var(--cream);
    border-radius: var(--radius-lg);
  }
  .feedback-note__stars {
    display: block;
    color: var(--terracotta);
    font-size: 1.4rem;
    letter-spacing: 0.2em;
    margin-bottom: var(--space-md);
  }
  .feedback-note h2 {
    color: var(--cream);
    margin-bottom: var(--space-md);
  }
  .feedback-note p {
    margin: 0 auto;
    max-width: 50ch;
    color: color-mix(in srgb, var(--cream) 82%, transparent);
  }
  .feedback-note__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
    justify-content: center;
    margin-top: var(--space-xl);
  }
  /* Ghost-Button auf dunklem Grund lesbar machen */
  .feedback-note .btn--ghost {
    color: var(--cream);
    border-color: color-mix(in srgb, var(--cream) 45%, transparent);
  }
  .feedback-note .btn--ghost:hover {
    background: var(--cream);
    color: var(--ink);
  }
</style>

<script>
  // Kundenstimmen: lange Texte einklappen und per "Mehr lesen" ausklappen.
  // Ohne JS bleibt der volle Text sichtbar (Progressive Enhancement).
  function setupTestimonials() {
    document.querySelectorAll('.testimonial').forEach((card) => {
      const text = card.querySelector('.testimonial__text') as HTMLElement | null;
      const btn = card.querySelector('.testimonial__toggle') as HTMLButtonElement | null;
      if (!text || !btn || btn.dataset.ready) return;

      text.classList.add('is-clamped');
      // Nur wenn der Text im eingeklappten Zustand überläuft, lohnt der Button.
      if (text.scrollHeight - text.clientHeight > 4) {
        btn.hidden = false;
        btn.dataset.ready = '1';
        btn.addEventListener('click', () => {
          const clamped = text.classList.toggle('is-clamped');
          btn.setAttribute('aria-expanded', String(!clamped));
          btn.textContent = clamped ? 'Mehr lesen' : 'Weniger anzeigen';
        });
      } else {
        // Kurzer Text: kein Einklappen nötig.
        text.classList.remove('is-clamped');
      }
    });
  }

  // Nach dem Laden der Schriften messen (sonst stimmen die Zeilenhöhen nicht).
  if (document.fonts && document.fonts.ready) {
    document.fonts.ready.then(setupTestimonials);
  } else {
    setupTestimonials();
  }
</script>
